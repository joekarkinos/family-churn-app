# Supabase — get from supabase.com → project → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_ID.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...your_anon_key...

# Only used in Edge Functions (server-side only — never expose to client)
SUPABASE_SERVICE_ROLE_KEY=eyJ...your_service_role_key...

# Firebase Cloud Messaging — for push notifications (Android)
# Get from Firebase Console → Project Settings → Cloud Messaging
NEXT_PUBLIC_FCM_VAPID_KEY=B...your_vapid_key...
FCM_SERVER_KEY=AAAA...your_server_key...
